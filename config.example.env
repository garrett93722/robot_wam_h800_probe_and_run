# Copy this file to config.env on the GPU server, then edit the paths.
# Do not write real tokens into files committed to Git or shared with others.

# Your remote SSH tree should look like:
#   <project_root>/robot_wam_h800_probe_and_run
#   <project_root>/sources
# Keep PROJECT_ROOT as the parent directory of this file's folder.
THIS_CONFIG_FILE="${BASH_SOURCE[0]:-${0}}"
THIS_CONFIG_DIR="$(cd "$(dirname "${THIS_CONFIG_FILE}")" && pwd)"
PROJECT_ROOT="$(cd "${THIS_CONFIG_DIR}/.." && pwd)"
SOURCE_ROOT="${PROJECT_ROOT}/sources"

HF_HOME="${PROJECT_ROOT}/.cache/huggingface"
HF_TOKEN=""
MODELSCOPE_CACHE="${PROJECT_ROOT}/.cache/modelscope"
# 2xH800 target: expose both GPUs by default.
CUDA_VISIBLE_DEVICES="0,1"
DREAMZERO_CUDA_VISIBLE_DEVICES="0,1"

LINGBOT_REPO="${SOURCE_ROOT}/lingbot-va"
DREAMZERO_REPO="${SOURCE_ROOT}/dreamzero"
LIBERO_REPO="${SOURCE_ROOT}/LIBERO"

LINGBOT_CKPT_DIR="${PROJECT_ROOT}/checkpoints/lingbot-va-posttrain-libero-long"
DREAMZERO_CKPT_DIR="${PROJECT_ROOT}/checkpoints/DreamZero-DROID"
DREAMZERO_AGIBOT_CKPT_DIR="${PROJECT_ROOT}/checkpoints/DreamZero-AgiBot"
LIBERO_DATA_DIR="${PROJECT_ROOT}/data/libero"
LOG_DIR="${PROJECT_ROOT}/robot_wam_h800_probe_and_run/logs"

LINGBOT_ENV_NAME="lingbot_va"
DREAMZERO_ENV_NAME="dreamzero"
LIBERO_ENV_NAME="libero"

LINGBOT_MODEL_ID="robbyant/lingbot-va-posttrain-libero-long"
LINGBOT_MODELSCOPE_ID="Robbyant/lingbot-va-posttrain-libero-long"
DREAMZERO_DROID_MODEL_ID="GEAR-Dreams/DreamZero-DROID"
DREAMZERO_AGIBOT_MODEL_ID="GEAR-Dreams/DreamZero-AgiBot"

LINGBOT_PORT="29056"
LINGBOT_MASTER_PORT="29061"
DREAMZERO_PORT="5000"
DREAMZERO_API_HOST="127.0.0.1"
DREAMZERO_API_PORT="5000"

# Tencent/Mainland network notes:
# - If HuggingFace is slow or blocked, prefer ModelScope where supported.
# - LingBot supports ModelScope fallback in 10_setup_lingbot_va.sh:
#   USE_MODELSCOPE=1 DOWNLOAD_LINGBOT_CKPT=1 CONFIRM_INSTALL=1 bash 10_setup_lingbot_va.sh
# - DreamZero official checkpoints are on HuggingFace; test network first with 00_probe_env.sh.
